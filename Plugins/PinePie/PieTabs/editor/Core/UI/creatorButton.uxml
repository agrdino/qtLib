<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <Style src="project://database/Assets/PinePie/PieTabs/editor/Core/UI/PieDeskStyling.uss?fileID=7433441132597879392&amp;guid=575cf5165b849494da86da44afc43d62&amp;type=3#PieDeskStyling" />
    <ui:VisualElement name="customButton" class="clickableButton" style="flex-grow: 0; height: 100%; flex-direction: row; flex-shrink: 0; justify-content: center; align-self: center; align-items: center; margin-right: 2px; margin-left: 0; border-top-left-radius: 3px; border-top-right-radius: 3px; border-bottom-right-radius: 3px; border-bottom-left-radius: 3px; padding-top: 2px; padding-right: 2px; padding-bottom: 2px; padding-left: 4px;">
        <ui:Label tabindex="-1" text="A" parse-escape-sequences="true" display-tooltip-when-elided="true" name="buttonLabel" picking-mode="Ignore" style="justify-content: center; align-items: center; align-self: center; -unity-text-align: middle-center; -unity-font-style: bold; padding-right: 4px; padding-left: 4px;" />
        <ui:VisualElement name="shade" picking-mode="Ignore" style="flex-grow: 0; flex-direction: row; flex-shrink: 0; justify-content: center; align-self: center; align-items: center; margin-right: 1px; margin-left: 1px; border-top-left-radius: 3px; border-top-right-radius: 3px; border-bottom-right-radius: 3px; border-bottom-left-radius: 3px; padding-top: 2px; padding-right: 2px; padding-bottom: 2px; padding-left: 4px; position: absolute; left: 0; top: 0; right: 0; bottom: 0;" />
    </ui:VisualElement>
</ui:UXML>
